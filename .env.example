# ─────────────────────────────────────────────────────────────
# Variables de entorno del frontend (Vite).
# Copia este archivo a ".env.local" y rellena con tus valores.
# NUNCA subas .env.local al repositorio (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────

# URL de tu proyecto Supabase (Settings → API)
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Clave pública "anon" de Supabase (Settings → API). Es pública por diseño;
# la seguridad real la dan las políticas RLS de la base de datos.
VITE_SUPABASE_ANON_KEY=tu-anon-key-publica


# ─────────────────────────────────────────────────────────────
# Observabilidad (opcional). Si se dejan vacías, no se carga nada.
# ─────────────────────────────────────────────────────────────

# DSN de Sentry para monitoreo de errores en producción (Sentry → Project → Client Keys).
VITE_SENTRY_DSN=

# Dominio para analítica de producto con Plausible (ej. app.omicron.cl).
VITE_ANALYTICS_DOMAIN=

# ─────────────────────────────────────────────────────────────
# Compra de tokens (Stripe). Pon "true" SOLO cuando hayas configurado
# las claves de Stripe en las Edge Functions (ver más abajo). Si no,
# el botón "Recargar tokens" permanece oculto.
# ─────────────────────────────────────────────────────────────
VITE_STRIPE_ENABLED=false

# ─────────────────────────────────────────────────────────────
# SECRETOS DEL BACKEND (NO son del frontend). Se configuran en:
# Supabase → Project Settings → Edge Functions → Secrets.
# Se listan aquí solo como referencia; nunca los pongas en el frontend.
# ─────────────────────────────────────────────────────────────
#   STRIPE_SECRET_KEY        = sk_live_... (o sk_test_... para pruebas)
#   STRIPE_WEBHOOK_SECRET    = whsec_...   (del endpoint de webhook en Stripe)
#   PUBLIC_SITE_URL          = https://tu-dominio.cl (fallback de retorno de pago)
#   GEMINI_API_KEY           = clave de Google Gemini (ya en uso para IA)
