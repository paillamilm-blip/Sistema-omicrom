# Supabase
# Copia este archivo a .env.local y completa con tus credenciales.
# Si estas variables NO estan definidas, la app usa datos mock automaticamente
# (ver src/lib/data/*), por lo que puedes desarrollar sin backend.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Solo servidor (opcional, para operaciones privilegiadas)
SUPABASE_SERVICE_ROLE_KEY=
